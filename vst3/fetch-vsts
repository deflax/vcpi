#!/usr/bin/env bash
#
# fetch-vsts -- Download open-license VST3 plugins into the vst3/ directory.
#
# Usage:
#   ./vst3/fetch-vsts              # download all plugins
#   ./vst3/fetch-vsts dexed        # download only Dexed
#   ./vst3/fetch-vsts surge        # download only Surge XT
#   ./vst3/fetch-vsts odin         # download only Odin 2
#   ./vst3/fetch-vsts obxf         # download only OB-Xf
#   ./vst3/fetch-vsts geonkick     # download only Geonkick
#   ./vst3/fetch-vsts jc303        # download only JC-303
#   ./vst3/fetch-vsts firefly      # download Firefly Synth 2 and Firefly FX
#   ./vst3/fetch-vsts fireflyfx    # download only Firefly FX
#   ./vst3/fetch-vsts dragonfly    # download only Dragonfly Reverb
#   ./vst3/fetch-vsts synths       # download synths only
#   ./vst3/fetch-vsts effects      # download effects only
#
# Downloaded .vst3 bundles land in vst3/ and are automatically found by
# vcpi's "load vst" and "load fx" commands.
#
# Requirements: curl, unzip, tar

set -euo pipefail

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
VST_DIR="$SCRIPT_DIR"

# -- Plugin definitions --------------------------------------------------

# --- Synths ---

SURGE_VERSION="1.3.4"
SURGE_URL="https://github.com/surge-synthesizer/releases-xt/releases/download/${SURGE_VERSION}/surge-xt-linux-1.3.4-pluginsonly.tar.gz"
SURGE_ARCHIVE="surge-xt-linux-${SURGE_VERSION}-pluginsonly.tar.gz"
SURGE_VST3="Surge XT.vst3"

DEXED_VERSION="1.0.1"
DEXED_URL="https://github.com/asb2m10/dexed/releases/download/v${DEXED_VERSION}/Dexed-${DEXED_VERSION}-lnx.zip"
DEXED_ARCHIVE="Dexed-${DEXED_VERSION}-lnx.zip"
DEXED_VST3="Dexed.vst3"

ODIN_VERSION="2.4.1"
ODIN_URL="https://github.com/TheWaveWarden/odin2/releases/download/NightlyDevel/Odin2.4.1Linux.zip"
ODIN_ARCHIVE="Odin${ODIN_VERSION}Linux.zip"
ODIN_VST3="Odin2.vst3"

OBXF_URL="https://github.com/surge-synthesizer/OB-Xf/releases/download/Nightly/obxf-2026-02-17-56fd0b7-Linux.zip"
OBXF_ARCHIVE="obxf-nightly-linux.zip"
OBXF_VST3="OB-Xf.vst3"

GEONKICK_VERSION="3.7.0"
GEONKICK_URL="https://github.com/quamplex/geonkick/releases/download/v${GEONKICK_VERSION}/GNULinux_binaries_v${GEONKICK_VERSION}_basic.zip"
GEONKICK_ARCHIVE="geonkick-${GEONKICK_VERSION}-linux.zip"
GEONKICK_VST3="geonkick.vst3"

JC303_VERSION="0.12.3"
JC303_URL="https://github.com/midilab/jc303/releases/download/v${JC303_VERSION}/jc303-${JC303_VERSION}-linux_x64-plugins.zip"
JC303_ARCHIVE="jc303-${JC303_VERSION}-linux_x64-plugins.zip"
JC303_VST3="jc303.vst3"

FIREFLY_VERSION="2.1.0"
FIREFLY_URL="https://github.com/sjoerdvankreel/firefly-synth-2/releases/download/v${FIREFLY_VERSION}/FireflySynth2-linux-vst3-Release.zip"
FIREFLY_ARCHIVE="FireflySynth2-linux-vst3-${FIREFLY_VERSION}.zip"
FIREFLY_VST3="FireflySynth2.vst3"

FIREFLY_FX_URL="https://github.com/sjoerdvankreel/firefly-synth-2/releases/download/v${FIREFLY_VERSION}/FireflySynth2FX-linux-vst3-Release.zip"
FIREFLY_FX_ARCHIVE="FireflySynth2FX-linux-vst3-${FIREFLY_VERSION}.zip"
FIREFLY_FX_VST3="FireflySynth2FX.vst3"

# --- Effects ---

DRAGONFLY_VERSION="3.2.10"
DRAGONFLY_URL="https://github.com/michaelwillis/dragonfly-reverb/releases/download/${DRAGONFLY_VERSION}/dragonfly-reverb-${DRAGONFLY_VERSION}-linux-x86_64.tar.xz"
DRAGONFLY_ARCHIVE="dragonfly-reverb-${DRAGONFLY_VERSION}-linux-x86_64.tar.xz"
# Dragonfly ships 4 separate .vst3 bundles; we detect them dynamically.

# -- Helpers -------------------------------------------------------------

need() {
  if ! command -v "$1" &>/dev/null; then
    echo "Error: $1 is required but not found." >&2
    exit 1
  fi
}

download() {
  local url="$1" dest="$2"
  if [ -f "$dest" ]; then
    echo "  (archive already cached: $dest)"
    return
  fi
  echo "  Downloading $(basename "$dest") ..."
  curl -fSL --progress-bar -o "$dest" "$url"
}

find_vst3() {
  # Recursively find a .vst3 bundle anywhere under the given directory.
  # Returns the first match.
  local search_dir="$1" name="$2"
  find "$search_dir" -maxdepth 4 -type d -name "$name" 2>/dev/null | head -1
}

find_all_vst3() {
  # Find all .vst3 bundles under a directory.
  local search_dir="$1"
  find "$search_dir" -maxdepth 4 -type d -name "*.vst3" 2>/dev/null
}

# Generic install: extract archive, locate .vst3, copy to VST_DIR.
# Args: label archive_path tmp_dir expected_vst3_name extract_cmd...
install_generic() {
  local label="$1" archive="$2" tmp="$3" expected="$4"
  shift 4
  # remaining args = extract command

  echo "  Extracting ..."
  rm -rf "$tmp"
  mkdir -p "$tmp"
  "$@"

  local found
  found=$(find_vst3 "$tmp" "$expected")
  if [ -z "$found" ]; then
    found=$(find "$tmp" -maxdepth 4 -type d -name "*.vst3" 2>/dev/null | head -1)
  fi

  if [ -z "$found" ]; then
    echo "  Warning: could not locate .vst3 bundle in archive. Listing contents:"
    ls -R "$tmp" | head -40
    rm -rf "$tmp"
    return 1
  fi

  cp -a "$found" "$VST_DIR/"
  local installed_name
  installed_name=$(basename "$found")
  echo "  Installed: $VST_DIR/$installed_name"
  rm -rf "$tmp"
}

# Install all .vst3 bundles from an archive (for multi-plugin packs).
install_all_vst3s() {
  local tmp="$1"
  shift
  # remaining args = extract command

  echo "  Extracting ..."
  rm -rf "$tmp"
  mkdir -p "$tmp"
  "$@"

  local count=0
  while IFS= read -r bundle; do
    [ -z "$bundle" ] && continue
    cp -a "$bundle" "$VST_DIR/"
    local name
    name=$(basename "$bundle")
    echo "  Installed: $VST_DIR/$name"
    count=$((count + 1))
  done < <(find_all_vst3 "$tmp")

  if [ "$count" -eq 0 ]; then
    echo "  Warning: no .vst3 bundles found in archive."
    ls -R "$tmp" | head -40
    rm -rf "$tmp"
    return 1
  fi

  rm -rf "$tmp"
}

# -- Per-plugin install functions ----------------------------------------

install_surge() {
  echo "=== Surge XT ${SURGE_VERSION} (GPL-3.0) - Hybrid synth ==="

  if [ -d "$VST_DIR/$SURGE_VST3" ]; then
    echo "  Already installed: $VST_DIR/$SURGE_VST3"
    return
  fi

  need curl; need tar
  local archive="$VST_DIR/.cache/$SURGE_ARCHIVE"
  local tmp="$VST_DIR/.cache/surge-tmp"
  mkdir -p "$VST_DIR/.cache"
  download "$SURGE_URL" "$archive"
  install_generic "Surge XT" "$archive" "$tmp" "$SURGE_VST3" \
    tar xzf "$archive" -C "$tmp"
}

install_dexed() {
  echo "=== Dexed ${DEXED_VERSION} (GPL-3.0) - DX7 FM synth ==="

  if [ -d "$VST_DIR/$DEXED_VST3" ]; then
    echo "  Already installed: $VST_DIR/$DEXED_VST3"
    return
  fi

  need curl; need unzip
  local archive="$VST_DIR/.cache/$DEXED_ARCHIVE"
  local tmp="$VST_DIR/.cache/dexed-tmp"
  mkdir -p "$VST_DIR/.cache"
  download "$DEXED_URL" "$archive"
  install_generic "Dexed" "$archive" "$tmp" "$DEXED_VST3" \
    unzip -qo "$archive" -d "$tmp"
}

install_odin() {
  echo "=== Odin 2 ${ODIN_VERSION} (GPL-3.0) - Polyphonic synth ==="

  if [ -d "$VST_DIR/$ODIN_VST3" ]; then
    echo "  Already installed: $VST_DIR/$ODIN_VST3"
