  fi

  need curl; need unzip
  local archive="$VST_DIR/.cache/$OBXF_ARCHIVE"
  local tmp="$VST_DIR/.cache/obxf-tmp"
  mkdir -p "$VST_DIR/.cache"
  download "$OBXF_URL" "$archive"
  install_generic "OB-Xf" "$archive" "$tmp" "$OBXF_VST3" \
    unzip -qo "$archive" -d "$tmp"
}

install_geonkick() {
  echo "=== Geonkick ${GEONKICK_VERSION} (GPL-3.0) - Percussion synth ==="

  if [ -d "$VST_DIR/$GEONKICK_VST3" ]; then
    echo "  Already installed: $VST_DIR/$GEONKICK_VST3"
    return
  fi

  need curl; need unzip
  local archive="$VST_DIR/.cache/$GEONKICK_ARCHIVE"
  local tmp="$VST_DIR/.cache/geonkick-tmp"
  mkdir -p "$VST_DIR/.cache"
  download "$GEONKICK_URL" "$archive"
  install_generic "Geonkick" "$archive" "$tmp" "$GEONKICK_VST3" \
    unzip -qo "$archive" -d "$tmp"
}

install_jc303() {
  echo "=== JC-303 ${JC303_VERSION} (GPL-3.0) - TB-303 acid bass ==="

  if [ -d "$VST_DIR/$JC303_VST3" ]; then
    echo "  Already installed: $VST_DIR/$JC303_VST3"
    return
  fi

  need curl; need unzip
  local archive="$VST_DIR/.cache/$JC303_ARCHIVE"
  local tmp="$VST_DIR/.cache/jc303-tmp"
  mkdir -p "$VST_DIR/.cache"
