  local archive="$VST_DIR/.cache/$FIREFLY_FX_ARCHIVE"
  local tmp="$VST_DIR/.cache/firefly-fx-tmp"
  mkdir -p "$VST_DIR/.cache"
  download "$FIREFLY_FX_URL" "$archive"
  install_generic "Firefly Synth 2 FX" "$archive" "$tmp" "$FIREFLY_FX_VST3" \
    unzip -qo "$archive" -d "$tmp"
}

install_firefly() {
  install_firefly_synth
  install_firefly_fx
}

install_dragonfly() {
  echo "=== Dragonfly Reverb ${DRAGONFLY_VERSION} (GPL-3.0) - Reverb suite ==="

  # Dragonfly ships 4 .vst3 bundles: Hall, Room, Plate, Early Reflections.
  # Check if any are already present.
  local existing
  existing=$(find "$VST_DIR" -maxdepth 1 -type d -name "Dragonfly*Reverb.vst3" 2>/dev/null | head -1)
  if [ -n "$existing" ]; then
    echo "  Already installed (at least one Dragonfly reverb found)"
    return
  fi

  need curl; need tar
  local archive="$VST_DIR/.cache/$DRAGONFLY_ARCHIVE"
  local tmp="$VST_DIR/.cache/dragonfly-tmp"
  mkdir -p "$VST_DIR/.cache"
  download "$DRAGONFLY_URL" "$archive"
  install_all_vst3s "$tmp" \
    tar xJf "$archive" -C "$tmp"
}

# -- Group helpers -------------------------------------------------------

install_all_synths() {
  install_dexed
  install_surge
  install_odin
  install_obxf
  install_geonkick
  install_jc303
  install_firefly_synth
}

install_all_effects() {
  install_dragonfly
  install_firefly_fx
}

install_all() {
  install_all_synths
  install_all_effects
}

# -- Main ----------------------------------------------------------------

TARGETS="${1:-all}"

case "$TARGETS" in
  all)        install_all          ;;
  synths)     install_all_synths   ;;
  effects)    install_all_effects  ;;
  dexed)      install_dexed        ;;
  surge)      install_surge        ;;
  odin)       install_odin         ;;
  obxf)       install_obxf         ;;
  geonkick)   install_geonkick     ;;
  jc303)      install_jc303        ;;
  firefly)    install_firefly      ;;
  fireflyfx)  install_firefly_fx   ;;
  dragonfly)  install_dragonfly    ;;
  *)
    echo "Usage: $0 [all|synths|effects|dexed|surge|odin|obxf|geonkick|jc303|firefly|fireflyfx|dragonfly]" >&2
    exit 1
    ;;
esac

echo ""
echo "Done. VST3 plugins in: $VST_DIR/"
echo "Use in vcpi:  load vst <slot> <PluginName>"
echo "              load fx <PluginName> [slot|master]"
