  echo "=== Firefly Synth 2 FX ${FIREFLY_VERSION} (GPL-3.0) - FX plugin ==="

  if [ -d "$VST_DIR/$FIREFLY_FX_VST3" ]; then
    echo "  Already installed: $VST_DIR/$FIREFLY_FX_VST3"
    return
  fi

